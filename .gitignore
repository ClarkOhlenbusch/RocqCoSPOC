pipeline/evals/*/*.vos
pipeline/evals/*/*.vok
pipeline/evals/*/*.glob
pipeline/evals/*/*.aux

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# IDE
.vscode/settings.json.local
